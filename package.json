{
  "name": "masterok-web",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "next dev",
    "prebuild": "npx tsx scripts/generate-calculators-meta.ts",
    "build": "next build",
    "postbuild": "node scripts/ping-indexnow.js",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:specs": "npx tsx scripts/sync-specs-to-dart.ts",
    "sync:parity": "npx tsx scripts/generate-parity-fixtures.ts",
    "sync:meta": "npx tsx scripts/generate-calculators-meta.ts",
    "sync:all": "npm run sync:specs && npm run sync:parity && npm run sync:meta",
    "test:parity": "vitest run tests/parity.test.ts",
    "blog:images:check": "node scripts/optimize-ghost-images.mjs --dry-run",
    "blog:images:webp": "node scripts/optimize-ghost-images.mjs --write-files",
    "blog:images:ghost": "node scripts/optimize-ghost-images.mjs --write-ghost",
    "analyze": "ANALYZE=true npm run build",
    "analyze:server": "ANALYZE=true next build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@types/three": "^0.169.0",
    "dexie": "^4.4.2",
    "html-react-parser": "^6.0.0",
    "isomorphic-dompurify": "^3.7.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "langfuse": "^3.38.20",
    "lucide-react": "^0.575.0",
    "next": "^15.5.12",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.7",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "^15.5.12",
    "postcss": "8.5.12",
    "tailwindcss": "^4.2.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.0.7"
  },
  "overrides": {
    "postcss": "8.5.12"
  }
}
