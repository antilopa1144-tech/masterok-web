{
  "name": "masterok-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node -e \"fetch('https://www.google.com/ping?sitemap=https://getmasterok.ru/sitemap.xml').then(()=>console.log('Sitemap ping sent')).catch(()=>{})\"",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:ci": "node deploy-ci.mjs",
    "deploy:ci:skip-tests": "node deploy-ci.mjs --skip-tests",
    "sync:specs": "npx tsx scripts/sync-specs-to-dart.ts",
    "sync:parity": "npx tsx scripts/generate-parity-fixtures.ts",
    "sync:all": "npm run sync:specs && npm run sync:parity",
    "test:parity": "vitest run tests/parity.test.ts"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "basic-ftp": "^5.1.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "next": "^15.5.12",
    "react": "^18",
    "react-dom": "^18",
    "three": "^0.183.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.0.7"
  }
}
