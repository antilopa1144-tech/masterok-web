    { "key": "wallWidth", "unit": "m", "default_value": 4, "min": 0.5, "max": 30 },
    { "key": "wallHeight", "unit": "m", "default_value": 2.7, "min": 0.5, "max": 10 },
    { "key": "stoneType", "default_value": 0, "min": 0, "max": 2 },
    { "key": "jointWidth", "unit": "mm", "default_value": 10, "min": 0, "max": 20 },
    { "key": "needGrout", "default_value": 1, "min": 0, "max": 1 },
    { "key": "needPrimer", "default_value": 1, "min": 0, "max": 1 }
  ],
  "field_factors": {
