{
  "calculator_id": "linoleum",
  "formula_version": "linoleum-canonical-v1",
  "input_schema": [
    { "key": "inputMode", "default_value": 0, "min": 0, "max": 1 },
    { "key": "length", "unit": "m", "default_value": 5, "min": 1, "max": 30 },
    { "key": "width", "unit": "m", "default_value": 4, "min": 1, "max": 20 },
    { "key": "area", "unit": "m2", "default_value": 20, "min": 1, "max": 500 },
    { "key": "roomWidth", "unit": "m", "default_value": 4, "min": 1, "max": 20 },
    { "key": "perimeter", "unit": "m", "default_value": 0, "min": 0, "max": 200 },
    { "key": "rollWidth", "unit": "m", "default_value": 3.0, "min": 1.5, "max": 5 },
    { "key": "hasPattern", "default_value": 0, "min": 0, "max": 1 },
    { "key": "patternRepeatCm", "unit": "cm", "default_value": 30, "min": 0, "max": 100 },
    { "key": "needGlue", "default_value": 0, "min": 0, "max": 1 },
    { "key": "needPlinth", "default_value": 1, "min": 0, "max": 1 },
    { "key": "needTape", "default_value": 1, "min": 0, "max": 1 }
