    "primer_liters_per_m2": 0.15,
    "plinth_reserve_percent": 5,
    "default_door_opening_width_m": 0.9,
    "tape_extra_perimeter_run": 1
  },
  "warnings_rules": {
    "high_waste_percent_threshold": 25,
    "max_single_roll_width_m": 5,
    "low_roll_width_warning_threshold_m": 3
