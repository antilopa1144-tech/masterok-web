{
  "calculator_id": "foam-blocks",
  "formula_version": "foam-blocks-canonical-v1",
  "input_schema": [
    { "key": "inputMode", "default_value": 0, "min": 0, "max": 1 },
    { "key": "wallLength", "unit": "m", "default_value": 10, "min": 1, "max": 100 },
    { "key": "wallHeight", "unit": "m", "default_value": 2.7, "min": 1, "max": 5 },
    { "key": "area", "unit": "m2", "default_value": 27, "min": 1, "max": 500 },
    { "key": "openingsArea", "unit": "m2", "default_value": 5, "min": 0, "max": 50 },
    { "key": "blockSize", "default_value": 0, "min": 0, "max": 3 },
    { "key": "mortarType", "default_value": 0, "min": 0, "max": 1 }
  ],
  "field_factors": {
    "enabled": [
      "geometry_complexity",
      "worker_skill",
      "waste_factor"
    ]
  },
  "normative_formula": {
    "block_sizes": {
      "0": { "l": 600, "h": 300, "t": 200, "label": "Пеноблок 600×300×200" },
      "1": { "l": 600, "h": 300, "t": 100, "label": "Пеноблок 600×300×100" },
      "2": { "l": 390, "h": 190, "t": 188, "label": "Керамзитоблок 390×190×188" },
      "3": { "l": 390, "h": 190, "t": 90, "label": "Керамзитоблок 390×190×90" }
    }
  },
  "packaging_rules": {
    "unit": "шт",
