{
  "calculator_id": "waterproofing",
  "formula_version": "waterproofing-canonical-v1",
  "input_schema": [
    { "key": "floorArea", "unit": "m2", "default_value": 6, "min": 1, "max": 50 },
    { "key": "wallHeight", "unit": "mm", "default_value": 200, "min": 0, "max": 2000 },
    { "key": "roomPerimeter", "unit": "m", "default_value": 10, "min": 4, "max": 40 },
    { "key": "masticType", "default_value": 0, "min": 0, "max": 2 },
    { "key": "layers", "default_value": 2, "min": 1, "max": 3 }
