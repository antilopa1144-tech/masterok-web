# ============================================
# Search console verifications
# ============================================
NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=

# ============================================
# Настройки сайта
# ============================================
NEXT_PUBLIC_SITE_URL=https://getmasterok.ru
NEXT_PUBLIC_SITE_NAME="Мастерок — строительные калькуляторы"
NEXT_PUBLIC_SITE_DESCRIPTION="Онлайн-калькуляторы для расчёта строительных материалов"
NEXT_PUBLIC_SITE_KEYWORDS="строительные калькуляторы, расчёт материалов, смета, стройка"

# ============================================
# Яндекс.Метрика
# ============================================
NEXT_PUBLIC_YM_COUNTER=

# ============================================
# Ghost CMS (серверные, используются при билде)
# ============================================
GHOST_API_URL=http://5.129.248.119
GHOST_CONTENT_API_KEY=
# Только для scripts/optimize-ghost-images.mjs --write-ghost.
# Формат ключа Ghost Admin API: id:secret
GHOST_ADMIN_API_KEY=

# ============================================
# Михалыч (AI-помощник) — DeepSeek API
# Запросы ВСЕГДА идут через серверный route /api/mikhalych.
# Ключ хранится ТОЛЬКО здесь и не попадает в клиентский бандл.
# NEXT_PUBLIC_* вариант намеренно удалён — это было дырой (ключ утекал в APK/JS).
# Ключ: https://platform.deepseek.com/api_keys
# ============================================
DEEPSEEK_API_KEY=sk-...
# Опционально (дефолты: deepseek-v4-pro / deepseek-v4-flash)
# MIKHALYCH_MODEL=deepseek-v4-pro
# MIKHALYCH_REVIEW_MODEL=deepseek-v4-flash
# Старые id OpenRouter в env тоже мапятся: deepseek/deepseek-v4-pro → deepseek-v4-pro
# Fallback, если DeepSeek ещё не настроен (старый провайдер):
# OPENROUTER_API_KEY=sk-or-...

# Агент Михалыча (tools + калькуляторы + SSE) — по умолчанию включён на /api/mikhalych
# MIKHALYCH_AGENT_ENABLED=false
# MIKHALYCH_AGENT_MAX_TOOL_ROUNDS=8
# Поиск в сети (опционально): https://serper.dev
# SERPER_API_KEY=
# Чтение страниц как Markdown (опционально): https://jina.ai/reader
# JINA_API_KEY=
# Langfuse — трейсы tools/LLM: https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_ENABLED=false

# ============================================
# Только для Timeweb / Docker (не нужно локально)
# На продакшене /app read-only, npm не может писать логи в .npm-cache/_logs.
# Установите в Dashboard Timeweb → Настройки → Переменные окружения:
#   NPM_CONFIG_CACHE=/tmp/.npm-cache
# Это уберёт «npm error Log files were not written» при каждом рестарте.
# ============================================
# NPM_CONFIG_CACHE=/tmp/.npm-cache
