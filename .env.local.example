# ============================================
# Яндекс.Метрика
# ============================================
NEXT_PUBLIC_YM_COUNTER=

# ============================================
# Ghost CMS (серверные, используются при билде)
# ============================================
GHOST_API_URL=http://5.129.248.119
GHOST_CONTENT_API_KEY=

# ============================================
# Михалыч (AI-помощник) — OpenRouter
# В проде запросы идут через /api/mikhalych (серверный route).
# OPENROUTER_API_KEY — серверный, не попадает в бандл.
# NEXT_PUBLIC_OPENROUTER_API_KEY — только для локальной dev-разработки.
# ============================================
OPENROUTER_API_KEY=sk-or-...
NEXT_PUBLIC_OPENROUTER_API_KEY=sk-or-...
