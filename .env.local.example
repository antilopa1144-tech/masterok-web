# ============================================
# Google Search Console verification
# ============================================
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# ============================================
# Yandex Webmaster verification
# ============================================
NEXT_PUBLIC_YANDEX_VERIFICATION=

# ============================================
# OpenRouter API для Михалыча (клиентский ключ — ограничь по домену на openrouter.ai)
# ============================================
NEXT_PUBLIC_OPENROUTER_API_KEY=sk-or-...

# ============================================
# Настройки сайта
# ============================================
NEXT_PUBLIC_SITE_URL=https://getmasterok.ru
NEXT_PUBLIC_SITE_NAME="Мастерок — строительные калькуляторы"
NEXT_PUBLIC_SITE_DESCRIPTION="Онлайн-калькуляторы для расчёта строительных материалов"
NEXT_PUBLIC_SITE_KEYWORDS="строительные калькуляторы, расчёт материалов, смета, стройка"

# ============================================
# Аналитика и мониторинг
# ============================================
NEXT_PUBLIC_YM_COUNTER=  # Яндекс.Метрика (только серверная переменная)
NEXT_PUBLIC_GA_ID=       # Google Analytics (опционально)
SENTRY_DSN=             # Sentry DSN для отслеживания ошибок (опционально)
SENTRY_TRACING=true

# ============================================
# CORS настройки (для API запросов)
# ============================================
NEXT_PUBLIC_CORS_ORIGIN=https://getmasterok.ru
NEXT_PUBLIC_CORS_ALLOW_ALL=false

# ============================================
# OpenAI/LLM альтернативы
# ============================================
NEXT_PUBLIC_OPENAI_API_KEY=  # Если используете OpenAI вместо OpenRouter
ANTHROPIC_API_KEY=          # Для Claude API (опционально)

# ============================================
# Flutter приложение (для синхронизации версий)
# ============================================
FLUTTER_APP_VERSION=1.0.0
FLUTTER_APP_STORE_URL=https://play.google.com/store/apps/details?id=com.masterok.app

# ============================================
# ПWA настройки
# ============================================
NEXT_PUBLIC_PWA_ENABLED=true
NEXT_PUBLIC_MANIFEST_PATH=/public/manifest.json

# ============================================
# Strapi CMS (серверные, используются только при билде)
# ============================================
STRAPI_API_URL=http://localhost:1337
STRAPI_API_TOKEN=                      # Read-only API token

# ============================================
# Другие сервисы
# ============================================
SENDGRID_API_KEY=         # Для email уведомлений (опционально)
RECAPTCHA_SITE_KEY=       # Google reCAPTCHA (опционально)
STRIPE_PUBLISHABLE_KEY=   # Для оплаты премиум функций (опционально)
